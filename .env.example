# Copy to .env for local overrides (never commit .env)

APP_ENV=development
# production: APP_ENV=production + strong SECRET_KEY and ADMIN_TOKEN

SECRET_KEY=
# Optional: comma-separated previous keys during rotation window
SECRET_KEY_PREVIOUS=
ADMIN_TOKEN=
REGION_FOCUS=Bayern
SUPPORT_EMAIL=your@email.com

# Closed beta access (leave empty to disable gate locally)
BETA_ACCESS_PASSWORD=
BETA_INVITE_TOKENS=solarpath-beta-2026

# Database — SQLite by default (data/solarpath.db)
# Docker / Codespaces (set in GitHub Codespaces secrets, not in this file):
# POSTGRES_USER=solarpath
# POSTGRES_PASSWORD=
# POSTGRES_DB=solarpath
# DATABASE_URL is built automatically in docker-compose from the POSTGRES_* vars
# Postgres on Render:
# DATABASE_URL=postgresql://user:pass@host:5432/solarpath

# Stripe — beta uses demo checkout only unless STRIPE_LIVE_ENABLED=1
STRIPE_LIVE_ENABLED=0
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_VERIFIED=price_...
# STRIPE_PRICE_PREMIUM=price_...

# SMTP — without host/user, emails go to data/email_log.txt + data/email_outbox/
SMTP_FROM=noreply@yourdomain.com
# Gmail (recommended for Render — use an App Password, not your login password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_USE_TLS=1
# SSL-only providers (port 465):
# SMTP_USE_SSL=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# On Render: set SMTP_PASSWORD in the dashboard (sync: false in render.yaml)

# Google Solar API (building insights for roof analysis)
# GOOGLE_SOLAR_API_KEY=

# EV dealer featured listing (Stripe one-time payment)
# EV_FEATURED_PRICE_EUR=49
# EV_FEATURED_DURATION_DAYS=30
# STRIPE_PRICE_EV_FEATURED=price_...

# Production (Render dashboard)
# FLASK_ENV=production
# FLASK_DEBUG=0
# LOG_FILE=data/solarpath.log
# Auth anomaly lockout (optional overrides)
# ANOMALY_WINDOW_SECONDS=300
# ANOMALY_MAX_FAILURES=8
# ANOMALY_BLOCK_SECONDS=900
# Set SECRET_KEY, ADMIN_TOKEN, DATABASE_URL, and SMTP_* in Render Environment
