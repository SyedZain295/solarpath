# Copy to .env for local overrides (never commit .env)

SECRET_KEY=
ADMIN_TOKEN=
REGION_FOCUS=Bayern
SUPPORT_EMAIL=your@email.com

# Closed beta access (leave empty to disable gate locally)
BETA_ACCESS_PASSWORD=
BETA_INVITE_TOKENS=solarpath-beta-2026

# Database — SQLite by default (data/solarpath.db)
# Postgres on Render:
# DATABASE_URL=postgresql://user:pass@host:5432/solarpath

# Stripe — beta uses demo checkout only unless STRIPE_LIVE_ENABLED=1
STRIPE_LIVE_ENABLED=0
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_VERIFIED=price_...
# STRIPE_PRICE_PREMIUM=price_...

# SMTP — without host/user, emails go to data/email_log.txt + data/email_outbox/
SMTP_FROM=noreply@yourdomain.com
# Gmail / SendGrid (STARTTLS, port 587):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SSL-only providers (port 465):
# SMTP_USE_SSL=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465

# Production (Render dashboard)
# FLASK_ENV=production
# FLASK_DEBUG=0
# LOG_FILE=data/solarpath.log
# Set SECRET_KEY, ADMIN_TOKEN, DATABASE_URL, and SMTP_* in Render Environment
